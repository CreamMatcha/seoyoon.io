---
//Imports
import Base from "@layouts/Base.astro";
import "@styles/markdown.css";

// Get current language from URL
export function getStaticPaths() {
    return [
        // English route: /about
        // Since this file is in [about] folder, the [about] param becomes "about"
        // [...index] = undefined means no additional URL segments after /about
        {
            params: { pages: "pages", index: undefined },
            props: { lang: "en" },
        },
        // Korean route: /ko/pages
        // [pages] = "ko" acts as language prefix in URL
        // [...index] = "pages" reuses the English page name after /ko/
        // This creates the final URL: /ko/pages
        {
            params: { pages: "ko", index: "pages" },
            props: { lang: "ko" },
        },
    ];
}

// Props
const { lang } = Astro.props;

// Dynamically import the correct MDX file based on the language
const { Content, frontmatter } = await import(`./_pages-${lang}.mdx`);
---

<Base
    title={frontmatter?.title}
    meta={{
        description: frontmatter?.description,
        keywords: frontmatter?.keywords,
    }}
>
    <section id="md-content" aria-label="Page content">
        <Content />
    </section>
</Base>
